# Copy this file to .env and fill in your API keys.
# Never commit .env — it is listed in .gitignore.
#
# Errata auto-detects providers from available keys. You only need to
# configure the providers you want to use. Models are selected via
# recipe ## Models or /config; there are no ERRATA_* env vars.

# ── Native providers (auto-detected; one default model per key) ──────────

# Anthropic  (default: claude-sonnet-4-6)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI  (default: gpt-4o)
# OPENAI_API_KEY=sk-...

# Google AI  (default: gemini-2.0-flash)
# GOOGLE_API_KEY=AIza...

# ── OpenRouter (single key, any model) ──────────────────────────────────

# OPENROUTER_API_KEY=sk-or-...
# Models use "provider/model" format in recipe ## Models, e.g.:
#   - anthropic/claude-sonnet-4-6
#   - meta-llama/llama-3-70b-instruct

# ── LiteLLM (self-hosted proxy) ─────────────────────────────────────────

# LITELLM_BASE_URL=http://localhost:4000/v1
# LITELLM_API_KEY=optional
# Models use "litellm/<model>" format in recipe ## Models, e.g.:
#   - litellm/claude-sonnet-4-6

# ── Amazon Bedrock ──────────────────────────────────────────────────────

# Uses the AWS SDK default credential chain (AWS_ACCESS_KEY_ID +
# AWS_SECRET_ACCESS_KEY, AWS_PROFILE, or IAM role).
# AWS_REGION=us-east-1
# Models use "bedrock/<model>" format in recipe ## Models, e.g.:
#   - bedrock/anthropic.claude-sonnet-4-20250514-v1:0

# ── Azure OpenAI ────────────────────────────────────────────────────────

# Both key and endpoint are required.
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://myresource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-10-21
# Models use "azure/<deployment>" format in recipe ## Models, e.g.:
#   - azure/gpt-4o

# ── Vertex AI (Google Cloud) ────────────────────────────────────────────

# Uses Application Default Credentials (gcloud auth or
# GOOGLE_APPLICATION_CREDENTIALS). Both project and location are required.
# VERTEX_AI_PROJECT=my-gcp-project
# VERTEX_AI_LOCATION=us-central1
# Models use "vertex/<model>" format in recipe ## Models, e.g.:
#   - vertex/gemini-2.0-flash
