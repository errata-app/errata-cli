# Copy this file to .env and fill in your API keys
# Never commit .env

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# Optional: override default active models (comma-separated)
# ERRATA_ACTIVE_MODELS=claude-opus-4-6,claude-sonnet-4-6,gpt-4o

# Optional: override default model for each provider
# ERRATA_DEFAULT_ANTHROPIC_MODEL=claude-sonnet-4-6
# ERRATA_DEFAULT_OPENAI_MODEL=gpt-4o
# ERRATA_DEFAULT_GEMINI_MODEL=gemini-2.0-flash
